#include <vector>

using namespace std;

class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        // Edge case: if the array is empty, return 0
        if (nums.empty()) return 0;
        
        // 'i' is the index of the last unique element found
        int i = 0;
        
        // 'j' explores the rest of the array
        for (int j = 1; j < nums.size(); j++) {
            // If we find a value different from our last unique value
            if (nums[j] != nums[i]) {
                i++;             // Move to the next "unique" slot
                nums[i] = nums[j]; // Update it with the new unique value
            }
        }
        
        // The number of unique elements is the index + 1
        return i + 1;
    }
};
