#include <string>
#include <vector>

class Solution {
public:
    int numDecodings(std::string s) {
        if (s.empty() || s[0] == '0') return 0;

        int n = s.length();
        // dp[i] stores the number of ways to decode the substring s[0...i-1]
        std::vector<int> dp(n + 1, 0);
        
        // Base cases
        dp[0] = 1; // Empty string has one way to be decoded
        dp[1] = 1; // First character is not '0', so one way

        for (int i = 2; i <= n; i++) {
            // Check single-digit decoding (s[i-1])
            int singleDigit = s[i - 1] - '0';
            if (singleDigit >= 1 && singleDigit <= 9) {
                dp[i] += dp[i - 1];
            }

            // Check two-digit decoding (s[i-2...i-1])
            int doubleDigit = std::stoi(s.substr(i - 2, 2));
            if (doubleDigit >= 10 && doubleDigit <= 26) {
                dp[i] += dp[i - 2];
            }
        }

        return dp[n];
    }
};
