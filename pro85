#include <vector>
#include <stack>
#include <algorithm>

class Solution {
public:
    int maximalRectangle(std::vector<std::vector<char>>& matrix) {
        if (matrix.empty()) return 0;
        
        int rows = matrix.size();
        int cols = matrix[0].size();
        std::vector<int> heights(cols, 0);
        int maxArea = 0;

        for (int i = 0; i < rows; i++) {
            for (int j = 0; j < cols; j++) {
                // If cell is '1', add to current height; otherwise, reset to 0
                if (matrix[i][j] == '1') {
                    heights[j]++;
                } else {
                    heights[j] = 0;
                }
            }
            // Calculate the largest rectangle for the current row's histogram
            maxArea = std::max(maxArea, largestRectangleInHistogram(heights));
        }

        return maxArea;
    }

private:
    int largestRectangleInHistogram(std::vector<int>& heights) {
        std::stack<int> s;
        int maxA = 0;
        int n = heights.size();

        for (int i = 0; i <= n; i++) {
            int h = (i == n) ? 0 : heights[i];
            while (!s.empty() && h < heights[s.top()]) {
                int height = heights[s.top()];
                s.pop();
                int width = s.empty() ? i : i - s.top() - 1;
                maxA = std::max(maxA, height * width);
            }
            s.push(i);
        }
        return maxA;
    }
};
