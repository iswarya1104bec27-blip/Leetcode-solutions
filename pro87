#include <string>
#include <unordered_map>
#include <vector>
#include <algorithm>

class Solution {
    std::unordered_map<std::string, bool> memo;

public:
    bool isScramble(std::string s1, std::string s2) {
        // Base cases
        if (s1 == s2) return true;
        if (s1.length() != s2.length()) return false;
        
        // Check memoization table
        std::string key = s1 + "_" + s2;
        if (memo.count(key)) return memo[key];

        // Pruning: Scrambled strings must be anagrams (same character counts)
        std::vector<int> count(26, 0);
        for (int i = 0; i < s1.length(); i++) {
            count[s1[i] - 'a']++;
            count[s2[i] - 'a']--;
        }
        for (int c : count) {
            if (c != 0) return memo[key] = false;
        }

        int n = s1.length();
        for (int i = 1; i < n; i++) {
            // Case 1: No swap at the current split point i
            // Left matches Left AND Right matches Right
            if (isScramble(s1.substr(0, i), s2.substr(0, i)) && 
                isScramble(s1.substr(i), s2.substr(i))) {
                return memo[key] = true;
            }

            // Case 2: Swapped at the current split point i
            // s1's Left matches s2's Right AND s1's Right matches s2's Left
            if (isScramble(s1.substr(0, i), s2.substr(n - i)) && 
                isScramble(s1.substr(i), s2.substr(0, n - i))) {
                return memo[key] = true;
            }
        }

        return memo[key] = false;
    }
};
