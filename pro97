#include <vector>
#include <string>

class Solution {
public:
    bool isInterleave(std::string s1, std::string s2, std::string s3) {
        int n = s1.length();
        int m = s2.length();
        
        // Base case: total length must match
        if (n + m != s3.length()) return false;

        // dp[j] will represent if s1[0...i] and s2[0...j] can form s3[0...i+j]
        std::vector<bool> dp(m + 1, false);

        for (int i = 0; i <= n; i++) {
            for (int j = 0; j <= m; j++) {
                if (i == 0 && j == 0) {
                    // Empty strings interleave to form empty string
                    dp[j] = true;
                } else if (i == 0) {
                    // Check only s2 against s3 (first row)
                    dp[j] = dp[j - 1] && s2[j - 1] == s3[j - 1];
                } else if (j == 0) {
                    // Check only s1 against s3 (first column update)
                    dp[j] = dp[j] && s1[i - 1] == s3[i - 1];
                } else {
                    // Current dp[j] is from top (s1), dp[j-1] is from left (s2)
                    dp[j] = (dp[j] && s1[i - 1] == s3[i + j - 1]) || 
                            (dp[j - 1] && s2[j - 1] == s3[i + j - 1]);
                }
            }
        }

        return dp[m];
    }
};
