#include <vector>

using namespace std;

class Solution {
public:
    int removeElement(vector<int>& nums, int val) {
        // 'k' tracks the count and index of elements not equal to 'val'
        int k = 0;
        
        for (int i = 0; i < nums.size(); i++) {
            // If current element is not the one we want to remove
            if (nums[i] != val) {
                // Move it to the 'k'-th position
                nums[k] = nums[i];
                k++;
            }
        }
        
        // 'k' is the number of elements that are not equal to 'val'
        return k;
    }
};
