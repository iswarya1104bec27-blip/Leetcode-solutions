class Solution {
public:
    TreeNode* sortedListToBST(ListNode* head) {
        // 1. Calculate the length of the linked list
        int n = 0;
        ListNode* curr = head;
        while (curr) {
            n++;
            curr = curr->next;
        }
        
        // 2. Build the tree using the current head pointer
        return buildBST(head, 0, n - 1);
    }

private:
    TreeNode* buildBST(ListNode*& head, int left, int right) {
        if (left > right) return nullptr;

        int mid = left + (right - left) / 2;

        // Build left subtree first
        TreeNode* leftChild = buildBST(head, left, mid - 1);

        // Process current head as the root
        TreeNode* root = new TreeNode(head->val);
        root->left = leftChild;
        
        // Move the actual head pointer forward for the next node
        head = head->next;

        // Build right subtree
        root->right = buildBST(head, mid + 1, right);

        return root;
    }
};
