#include <vector>

class Solution {
public:
    int removeDuplicates(std::vector<int>& nums) {
        int n = nums.size();
        if (n <= 2) return n;

        // k is the pointer for the next position to write to
        int k = 2; 

        for (int i = 2; i < n; i++) {
            // Compare current element with the element two positions back in result
            if (nums[i] != nums[k - 2]) {
                nums[k] = nums[i];
                k++;
            }
        }

        return k;
    }
};
