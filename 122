#include <vector>

class Solution {
public:
    int maxProfit(std::vector<int>& prices) {
        int totalProfit = 0;
        
        for (int i = 1; i < prices.size(); i++) {
            // If the price today is higher than yesterday, 
            // "buy" yesterday and "sell" today.
            if (prices[i] > prices[i - 1]) {
                totalProfit += (prices[i] - prices[i - 1]);
            }
        }
        
        return totalProfit;
    }
};
