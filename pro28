#include <string>

using namespace std;

class Solution {
public:
    int strStr(string haystack, string needle) {
        int n = haystack.length();
        int m = needle.length();
        
        // If needle is longer than haystack, it can't be found
        if (m > n) return -1;
        
        // Sliding window: only need to check up to n - m
        for (int i = 0; i <= n - m; i++) {
            // Check if the substring starting at i matches needle
            // Using substr() is clean, but you could also use a nested loop
            if (haystack.substr(i, m) == needle) {
                return i;
            }
        }
        
        return -1;
    }
};
