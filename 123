#include <vector>
#include <algorithm>
#include <climits>

class Solution {
public:
    int maxProfit(std::vector<int>& prices) {
        // Initialise states:
        // buy1/buy2: Max money after buying (should be negative/minimal)
        // sell1/sell2: Max money after selling
        int buy1 = INT_MIN, sell1 = 0;
        int buy2 = INT_MIN, sell2 = 0;

        for (int p : prices) {
            // 1. Max profit after 1st buy: remaining money after buying at price p
            buy1 = std::max(buy1, -p);
            
            // 2. Max profit after 1st sell: current price + money after 1st buy
            sell1 = std::max(sell1, buy1 + p);
            
            // 3. Max profit after 2nd buy: money after 1st sell - current price p
            buy2 = std::max(buy2, sell1 - p);
            
            // 4. Max profit after 2nd sell: current price + money after 2nd buy
            sell2 = std::max(sell2, buy2 + p);
        }

        return sell2;
    }
};
