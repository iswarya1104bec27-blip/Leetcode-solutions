#include <vector>

class Solution {
public:
    std::vector<int> plusOne(std::vector<int>& digits) {
        int n = digits.size();

        // Traverse from right to left
        for (int i = n - 1; i >= 0; i--) {
            // If digit is less than 9, just increment and return
            if (digits[i] < 9) {
                digits[i]++;
                return digits;
            }
            // If digit is 9, it becomes 0 and we continue to the next left digit
            digits[i] = 0;
        }

        // If we exit the loop, it means all digits were 9 (e.g., 999 -> 000)
        // We need to add a '1' at the beginning (e.g., 1000)
        digits.insert(digits.begin(), 1);
        return digits;
    }
};
