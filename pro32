#include <string>
#include <stack>
#include <algorithm>

using namespace std;

class Solution {
public:
    int longestValidParentheses(string s) {
        stack<int> st;
        st.push(-1); // Base index for the first valid substring
        int maxLen = 0;

        for (int i = 0; i < s.length(); i++) {
            if (s[i] == '(') {
                st.push(i);
            } else {
                st.pop();
                if (st.empty()) {
                    // Current ')' is a break point, use it as new base
                    st.push(i);
                } else {
                    // Calculate length from current index to the new top
                    maxLen = max(maxLen, i - st.top());
                }
            }
        }
        return maxLen;
    }
};
