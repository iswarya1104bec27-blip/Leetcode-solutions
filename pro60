#include <string>
#include <vector>
#include <numeric>

class Solution {
public:
    std::string getPermutation(int n, int k) {
        std::vector<int> numbers;
        std::vector<int> factorial(n);
        factorial[0] = 1;

        // Precompute factorials and create a list of digits [1, 2, ..., n]
        for (int i = 1; i < n; ++i) {
            factorial[i] = factorial[i - 1] * i;
            numbers.push_back(i);
        }
        numbers.push_back(n);

        // Convert k to 0-indexed for easier math
        k--;

        std::string result = "";
        for (int i = n - 1; i >= 0; --i) {
            // Determine the index of the current digit
            int index = k / factorial[i];
            result += std::to_string(numbers[index]);
            
            // Remove used digit from the list
            numbers.erase(numbers.begin() + index);
            
            // Update k for the next position
            if (i > 0) {
                k %= factorial[i];
            }
        }

        return result;
    }
};
