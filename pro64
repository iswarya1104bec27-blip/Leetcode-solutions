#include <vector>
#include <algorithm>

class Solution {
public:
    int minPathSum(std::vector<std::vector<int>>& grid) {
        int m = grid.size();
        int n = grid[0].size();
        
        // Use a 1D vector to store the minimum sums for the current row
        std::vector<int> dp(n);

        // Initialize the first cell
        dp[0] = grid[0][0];

        // Initialize the first row (can only come from the left)
        for (int j = 1; j < n; ++j) {
            dp[j] = dp[j - 1] + grid[0][j];
        }

        // Fill the rest of the grid row by row
        for (int i = 1; i < m; ++i) {
            // First element of each row can only come from above
            dp[0] += grid[i][0];
            
            for (int j = 1; j < n; ++j) {
                // dp[j] is the value from above, dp[j-1] is the value from the left
                dp[j] = grid[i][j] + std::min(dp[j], dp[j - 1]);
            }
        }

        return dp[n - 1];
    }
};
