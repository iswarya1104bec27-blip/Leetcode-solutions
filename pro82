class Solution {
public:
    ListNode* deleteDuplicates(ListNode* head) {
        // Dummy node to simplify edge cases (like removing the head)
        ListNode* dummy = new ListNode(0, head);
        ListNode* prev = dummy;

        while (head) {
            // If current node is a start of a duplicate sequence
            if (head->next && head->val == head->next->val) {
                // Skip all nodes with the same value
                while (head->next && head->val == head->next->val) {
                    head = head->next;
                }
                // Link prev to the node after the last duplicate
                prev->next = head->next;
            } else {
                // No duplicate found, move prev pointer forward
                prev = prev->next;
            }
            // Move head pointer forward
            head = head->next;
        }

        ListNode* result = dummy->next;
        delete dummy; // Clean up memory
        return result;
    }
};
