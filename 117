class Solution {
public:
    Node* connect(Node* root) {
        Node* curr = root; // Pointer to traverse the current level
        
        while (curr) {
            Node dummy(0);      // Dummy node for the next level
            Node* tail = &dummy; // Tail pointer to build the next level's list
            
            // Traverse the current level using 'next' pointers
            while (curr) {
                if (curr->left) {
                    tail->next = curr->left;
                    tail = tail->next;
                }
                if (curr->right) {
                    tail->next = curr->right;
                    tail = tail->next;
                }
                curr = curr->next;
            }
            
            // Move curr to the start of the next level we just built
            curr = dummy.next;
        }
        
        return root;
    }
};
