#include <vector>
#include <algorithm>

using namespace std;

class Solution {
public:
    int jump(vector<int>& nums) {
        int n = nums.size();
        if (n <= 1) return 0;

        int jumps = 0;
        int current_end = 0;
        int farthest = 0;

        // Iterate until the second to last element
        for (int i = 0; i < n - 1; i++) {
            // Update the furthest we can reach from current position
            farthest = max(farthest, i + nums[i]);

            // If we've reached the end of the range for the current jump
            if (i == current_end) {
                jumps++;
                current_end = farthest;

                // Optimization: If we can already reach the end, stop
                if (current_end >= n - 1) break;
            }
        }

        return jumps;
    }
};
