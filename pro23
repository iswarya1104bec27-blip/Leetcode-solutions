#include <vector>
#include <queue>
using namespace std;

/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */

class Solution {
public:
    // Custom comparator to ensure the priority queue acts as a min-heap
    struct compare {
        bool operator()(ListNode* a, ListNode* b) {
            return a->val > b->val;
        }
    };

    ListNode* mergeKLists(vector<ListNode*>& lists) {
        // Min-heap storing the heads of the lists
        priority_queue<ListNode*, vector<ListNode*>, compare> pq;

        // 1. Initial Step: Push the head of each non-empty list
        for (ListNode* head : lists) {
            if (head != nullptr) {
                pq.push(head);
            }
        }

        // Dummy node to help build the final list easily
        ListNode dummy(0);
        ListNode* tail = &dummy;

        // 2. Process the heap
        while (!pq.empty()) {
            // Get the smallest node available
            ListNode* smallest = pq.top();
            pq.pop();

            // Add it to our merged list
            tail->next = smallest;
            tail = tail->next;

            // If the popped node has a next element, push it into the heap
            if (smallest->next != nullptr) {
                pq.push(smallest->next);
            }
        }

        return dummy.next;
    }
};
