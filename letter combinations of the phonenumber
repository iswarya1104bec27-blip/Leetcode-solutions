#include <vector>
#include <string>

using namespace std;

class Solution {
private:
    // Mapping of digits to letters based on the phone keypad
    const vector<string> mapping = {
        "", "", "abc", "def", "ghi", "jkl", "mno", "pqrs", "tuv", "wxyz"
    };

    void backtrack(string& digits, int index, string& current, vector<string>& result) {
        // Base case: if current string length matches input digits length
        if (index == digits.length()) {
            result.push_back(current);
            return;
        }

        // Get the letters corresponding to the current digit
        string letters = mapping[digits[index] - '0'];

        for (char c : letters) {
            current.push_back(c);           // Choose a letter
            backtrack(digits, index + 1, current, result); // Recurse to next digit
            current.pop_back();              // Backtrack (undo choice)
        }
    }

public:
    vector<string> letterCombinations(string digits) {
        if (digits.empty()) return {}; // Handle edge case for empty input
        
        vector<string> result;
        string current = "";
        backtrack(digits, 0, current, result);
        return result;
    }
};
