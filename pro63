#include <vector>

class Solution {
public:
    int uniquePathsWithObstacles(std::vector<std::vector<int>>& obstacleGrid) {
        int m = obstacleGrid.size();
        int n = obstacleGrid[0].size();

        // If the start or end is an obstacle, no paths are possible
        if (obstacleGrid[0][0] == 1 || obstacleGrid[m - 1][n - 1] == 1) {
            return 0;
        }

        // dp[j] stores the number of ways to reach the current cell in column j
        std::vector<long> dp(n, 0);
        
        // Starting point base case
        dp[0] = 1;

        for (int i = 0; i < m; ++i) {
            for (int j = 0; j < n; ++j) {
                if (obstacleGrid[i][j] == 1) {
                    // Path is blocked
                    dp[j] = 0;
                } else if (j > 0) {
                    // New dp[j] = dp[j] (from above) + dp[j-1] (from left)
                    dp[j] += dp[j - 1];
                }
            }
        }

        return (int)dp[n - 1];
    }
};
